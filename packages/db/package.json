{
  "name": "@elite-message/db",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "lint": "eslint src --ext .ts",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:bootstrap:plain": "bash ./scripts/bootstrap-plain-postgres.sh",
    "db:reset": "prisma migrate reset --force --skip-seed"
  },
  "dependencies": {
    "@elite-message/config": "workspace:*",
    "@prisma/adapter-pg": "7.7.0",
    "@prisma/client": "7.7.0",
    "dotenv": "17.4.1",
    "pg": "8.16.3"
  },
  "devDependencies": {
    "@types/pg": "8.20.0",
    "prisma": "7.7.0"
  }
}
