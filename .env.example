# Shared
NODE_ENV=development
LOG_LEVEL=info
ENABLE_EXTERNAL_CONNECTIONS=true

# Customer web
CUSTOMER_WEB_APP_NAME=Elite Message Customer
CUSTOMER_WEB_PORT=3000
CUSTOMER_WEB_PUBLIC_BASE_URL=http://localhost:3000

# Admin web
ADMIN_WEB_APP_NAME=Elite Message Admin
ADMIN_WEB_PORT=3001
ADMIN_WEB_PUBLIC_BASE_URL=http://localhost:3001

# API
API_APP_NAME=Elite Message API
API_PORT=3002
API_BASE_URL=http://localhost:3002
API_ACCESS_TOKEN_TTL=15m
API_ACCESS_TOKEN_SECRET=change-me-super-secret
API_REFRESH_TOKEN_TTL=7d
API_COOKIE_DOMAIN=localhost
API_COOKIE_SECURE=false
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
API_INTERNAL_TOKEN=change-me
API_RATE_LIMIT_AUTH_WINDOW_MS=60000
API_RATE_LIMIT_AUTH_MAX_REQUESTS=10
API_RATE_LIMIT_PUBLIC_WINDOW_MS=60000
API_RATE_LIMIT_PUBLIC_MAX_REQUESTS=120
API_RATE_LIMIT_DASHBOARD_WINDOW_MS=60000
API_RATE_LIMIT_DASHBOARD_MAX_REQUESTS=240
API_RATE_LIMIT_ADMIN_WINDOW_MS=60000
API_RATE_LIMIT_ADMIN_MAX_REQUESTS=300
API_RATE_LIMIT_STRIKE_WINDOW_MS=900000
API_RATE_LIMIT_BLOCK_DURATION_MS=900000
API_RATE_LIMIT_STRIKE_THRESHOLD=5
API_WORKER_STALE_AFTER_MS=90000
API_REFRESH_SESSION_RETENTION_DAYS=30
API_WEBHOOK_DELIVERY_RETENTION_DAYS=14
API_AUDIT_LOG_RETENTION_DAYS=90
API_RETENTION_SWEEP_INTERVAL_MS=300000
API_WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300
API_GOOGLE_CLIENT_ID=
API_GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_API_BASE_URL=http://localhost:3002

# Observability
PROMETHEUS_PORT=9090
GRAFANA_PORT=3004
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
ALERTMANAGER_PORT=9093

# Worker
WORKER_APP_NAME=Elite Message Worker
WORKER_PORT=3003
WORKER_HEARTBEAT_INTERVAL_MS=30000
WORKER_CONTROL_LOOP_INTERVAL_MS=3000
WORKER_ID=worker-local-1
WORKER_REGION=local
WORKER_MAX_AUTO_ASSIGNMENTS=3
WORKER_SESSION_BACKEND=placeholder
WORKER_SESSION_STORAGE_DIR=/Volumes/MACOS/EliteMessage/.runtime/worker-sessions
WORKER_PLACEHOLDER_QR_DISPLAY_MS=300000
WORKER_WA_HEADLESS=true
WORKER_WA_BROWSER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
WORKER_WA_CAPTURE_SCREENSHOTS=false
WORKER_WA_DOWNLOAD_INBOUND_MEDIA=true
WORKER_WA_STARTUP_TIMEOUT_MS=120000
WORKER_WA_AUTO_RECOVERY_DELAY_MS=5000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=elite_message
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/elite_message?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# MinIO / S3-compatible storage
S3_ENDPOINT=http://localhost:9000
S3_PORT=9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=elite-message-local
S3_REGION=us-east-1

# Development bootstrap data
DEV_BOOTSTRAP_ADMIN_EMAIL=admin@elite.local
DEV_BOOTSTRAP_ADMIN_PASSWORD=Admin123456!
DEV_BOOTSTRAP_ADMIN_NAME=Elite Admin
DEV_BOOTSTRAP_CUSTOMER_EMAIL=owner@elite.local
DEV_BOOTSTRAP_CUSTOMER_PASSWORD=Customer123456!
DEV_BOOTSTRAP_CUSTOMER_NAME=Workspace Owner
DEV_BOOTSTRAP_WORKSPACE_NAME=Acme Workspace
